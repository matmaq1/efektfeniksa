<style is:global>
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }

  body {
    background-color: #141313;
    color: #e6e1e1;
    font-family: 'Manrope', sans-serif;
  }

  .font-noto-serif {
    font-family: 'Noto Serif', serif;
  }

  .glass-nav {
    background: rgba(20, 19, 19, 0.7);
    backdrop-filter: blur(20px);
  }

  .ember-glow:hover {
    box-shadow: 0px 0px 50px rgba(255, 107, 0, 0.4);
  }

  .btn-glow {
    box-shadow: 0px 0px 30px rgba(255, 107, 0, 0.3);
  }

  .btn-glow:hover {
    box-shadow: 0px 0px 50px rgba(255, 107, 0, 0.5);
  }

  .gradient-text {
    background: linear-gradient(45deg, #FF6B00, #FF8A00, #FF3D00);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .gradient-bg {
    background: linear-gradient(45deg, #FF6B00, #FF8A00);
  }

  .phoenix-ember-overlay {
    background: radial-gradient(circle at center, rgba(255, 107, 0, 0.1) 0%, transparent 70%);
    animation: drift 6s ease-in-out infinite;
  }

  @keyframes drift {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-20px);
    }
  }

  .asymmetric-line::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, #FF6B00, transparent);
  }
</style>
