---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Konkurs sztuki mówienia - Efekt Feniksa" } = Astro.props;

import Footer from '../components/Footer.astro';
import CustomCSS from '../components/CustomCSS.astro';
---

<!DOCTYPE html>
<html lang="pl" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title} - Efekt Feniksa</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400&family=Manrope:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <CustomCSS />
</head>
<body class="bg-surface text-on-surface overflow-x-hidden font-body leading-relaxed">
  <main class="min-h-screen">
    <slot />
  </main>
  <Footer />
</body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Noto Serif', serif;
    line-height: 1.2;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }

  .font-noto-serif {
    font-family: 'Noto Serif', serif;
  }
</style>
