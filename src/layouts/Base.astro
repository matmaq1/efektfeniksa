---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Konkurs sztuki mówienia - Efekt Feniksa" } = Astro.props;

import Nav from '../components/Nav.astro';
---

<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title} - Efekt Feniksa</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <Nav />
  <main>
    <slot />
  </main>
</body>
</html>

<style is:global>
  :root {
    --gold-primary: #775a19;
    --gold-light: #c5a059;
    --bg-ivory: #fcf9f8;
    --text-ebony: #1c1b1b;
    --shadow: 0px 20px 40px rgba(28, 27, 27, 0.06);
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: 'Manrope', sans-serif;
    background: var(--bg-ivory);
    color: var(--text-ebony);
    line-height: 1.6;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Noto Serif', serif;
    line-height: 1.2;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  main {
    min-height: 100vh;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .button {
    display: inline-block;
    padding: 0.875rem 2rem;
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 8px;
    transition: all 0.3s ease;
    cursor: pointer;
    border: 2px solid var(--gold-primary);
  }

  .button-primary {
    background: linear-gradient(135deg, var(--gold-primary), var(--gold-light));
    color: var(--bg-ivory);
    border-color: transparent;
  }

  .button-primary:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }

  .button-ghost {
    background: transparent;
    color: var(--gold-primary);
  }

  .button-ghost:hover {
    background: var(--gold-primary);
    color: var(--bg-ivory);
  }

  .section {
    padding: 5rem 0;
  }

  @media (max-width: 768px) {
    .section {
      padding: 3rem 0;
    }
  }
</style>
