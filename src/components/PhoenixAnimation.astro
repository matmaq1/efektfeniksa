---
---
<div class="phoenix-container absolute inset-0 flex items-center justify-center opacity-40 mix-blend-screen pointer-events-none overflow-hidden">
  <svg viewBox="0 0 800 800" class="phoenix-svg w-full h-full max-w-4xl">
    <defs>
      <filter id="glow">
        <feGaussianBlur stdDeviation="15" result="coloredBlur"/>
        <feMerge>
          <feMergeNode in="coloredBlur"/>
          <feMergeNode in="SourceGraphic"/>
        </feMerge>
      </filter>
      <linearGradient id="fire-grad" x1="0%" y1="100%" x2="0%" y2="0%">
        <stop offset="0%" style="stop-color:#FF0000; stop-opacity:1" />
        <stop offset="50%" style="stop-color:#FF6B00; stop-opacity:1" />
        <stop offset="100%" style="stop-color:#FFD700; stop-opacity:0.8" />
      </linearGradient>
    </defs>
    
    <!-- Wings -->
    <path class="wing wing-left" d="M400,400 Q200,300 100,500 T400,600" fill="url(#fire-grad)" filter="url(#glow)">
      <animate attributeName="d" 
        values="M400,400 Q200,300 100,500 T400,600; M400,400 Q150,200 50,400 T400,600; M400,400 Q200,300 100,500 T400,600" 
        dur="4s" repeatCount="indefinite" />
    </path>
    <path class="wing wing-right" d="M400,400 Q600,300 700,500 T400,600" fill="url(#fire-grad)" filter="url(#glow)">
      <animate attributeName="d" 
        values="M400,400 Q600,300 700,500 T400,600; M400,400 Q650,200 750,400 T400,600; M400,400 Q600,300 700,500 T400,600" 
        dur="4s" repeatCount="indefinite" />
    </path>
    
    <!-- Body -->
    <path class="body" d="M400,350 Q380,450 400,650 Q420,450 400,350" fill="url(#fire-grad)" filter="url(#glow)">
       <animate attributeName="transform"
          type="translate"
          values="0,0; 0,-20; 0,0"
          dur="3s" repeatCount="indefinite" />
    </path>
    
    <!-- Head -->
    <circle cx="400" cy="330" r="20" fill="url(#fire-grad)" filter="url(#glow)">
       <animate attributeName="cy"
          values="330; 310; 330"
          dur="3s" repeatCount="indefinite" />
    </circle>
  </svg>
</div>

<style>
  .phoenix-container {
    background: radial-gradient(circle at center, rgba(255, 107, 0, 0.15) 0%, transparent 70%);
  }
  
  .phoenix-svg {
    transform-origin: center;
    animation: slow-float 6s ease-in-out infinite, subtle-pulse 4s ease-in-out infinite;
  }

  @keyframes slow-float {
    0%, 100% { transform: translateY(0) scale(1.1); }
    50% { transform: translateY(-30px) scale(1.15); }
  }

  @keyframes subtle-pulse {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
  }

  .wing {
    transform-origin: 400px 400px;
  }
  
  .wing-left {
    animation: flap-left 4s ease-in-out infinite;
  }
  
  .wing-right {
    animation: flap-right 4s ease-in-out infinite;
  }

  @keyframes flap-left {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(-10deg); }
  }

  @keyframes flap-right {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(10deg); }
  }
</style>
