---
import Layout from '../layouts/Base.astro';
import { Nav, Footer } from '../components/Sections.jsx';
import { Agenda } from '../components/Agenda.jsx';
import { AGENDA_DAYS } from '../data/agenda.ts';
import '../styles/global.css';
---

<Layout title="Agenda | Efekt Feniksa">
  <div class="bg-background text-on-surface antialiased">
    <Nav active="agenda" client:load />
    
    <main class="pt-32 pb-20">
      <div class="max-w-screen-2xl mx-auto px-6 md:px-12 mb-16">
        <span class="text-primary font-bold tracking-[0.3em] uppercase text-xs mb-4 block">Program Wydarzenia</span>
        <h1 class="font-headline font-extrabold text-5xl md:text-7xl uppercase tracking-tighter mb-6">
          Pełna <span class="flame-text italic">Agenda</span>
        </h1>
        <p class="text-on-surface-variant text-lg max-w-2xl font-light leading-relaxed">
          Trzy dni intensywnej nauki, konkursów i networkingu. Zaplanuj swój udział w Efekcie Feniksa.
        </p>
      </div>

      <div class="bg-surface relative z-10">
        <Agenda days={AGENDA_DAYS} client:load />
      </div>
    </main>

    <Footer client:visible />
  </div>
</Layout>
