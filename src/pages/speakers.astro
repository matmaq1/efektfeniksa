---
import Base from '../layouts/Base.astro';

const speakers = [
  {
    name: 'Anna Kowalska',
    title: 'Ekspert retoryki',
    bio: 'Trenerka wystąpień publicznych z 15-letnim doświadczeniem. Autorka bestsellera "Sztuka Perswazji".'
  },
  {
    name: 'Michał Nowak',
    title: 'Coach public speaking',
    bio: 'Współpracował z setkami menedżerów i przedsiębiorców. Specjalista od komunikacji biznesowej.'
  },
  {
    name: 'Katarzyna Wiśniewska',
    title: 'Aktorka teatralna',
    bio: 'Laureatkaagrody teatralnej. Prowadzi warsztaty z emisji głosu i mowy scenicznej.'
  },
  {
    name: 'Tomasz Lewandowski',
    title: 'Mówca motywacyjny',
    bio: 'Inspiruje tysiące osób swoimi wystąpieniami. TEDx speaker i autor książek o rozwoju osobistym.'
  },
  {
    name: 'Magdalena Zielińska',
    title: 'Psycholog komunikacji',
    bio: 'Badaczka psychologii przekazu i wpływu społecznego. Wykładowca akademicki.'
  },
  {
    name: 'Paweł Dąbrowski',
    title: 'Dziennikarz i prezenter',
    bio: '20 lat doświadczenia w mediach. Prowadził największe programy informacyjne w Polsce.'
  }
];
---

<Base title="Prelegenci">
  <div class="speakers-hero">
    <div class="container">
      <h1 class="page-title">Nasi eksperci</h1>
      <p class="page-subtitle">Poznaj trenerów i wykładowców Efektu Feniksa</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="speakers-grid">
        {speakers.map((speaker) => (
          <article class="speaker-card">
            <div class="speaker-avatar">
              <div class="avatar-circle">
                {speaker.name.split(' ').map(n => n[0]).join('')}
              </div>
            </div>
            <h3 class="speaker-name">{speaker.name}</h3>
            <p class="speaker-title">{speaker.title}</p>
            <p class="speaker-bio">{speaker.bio}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .speakers-hero {
    padding: 8rem 0 4rem;
    background: linear-gradient(135deg, var(--gold-primary), var(--gold-light));
    text-align: center;
    color: var(--bg-ivory);
  }

  .page-title {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .page-subtitle {
    font-size: 1.25rem;
    opacity: 0.95;
  }

  .speakers-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  .speaker-card {
    background: white;
    padding: 2.5rem 2rem;
    border-radius: 12px;
    box-shadow: var(--shadow);
    text-align: center;
    transition: transform 0.3s ease;
  }

  .speaker-card:hover {
    transform: translateY(-8px);
  }

  .speaker-avatar {
    margin-bottom: 1.5rem;
  }

  .avatar-circle {
    width: 120px;
    height: 120px;
    margin: 0 auto;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--gold-primary), var(--gold-light));
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Noto Serif', serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--bg-ivory);
    box-shadow: var(--shadow);
  }

  .speaker-name {
    font-size: 1.5rem;
    color: var(--text-ebony);
    margin-bottom: 0.5rem;
  }

  .speaker-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--gold-primary);
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .speaker-bio {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--text-ebony);
    opacity: 0.8;
  }

  @media (min-width: 640px) {
    .speakers-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .speakers-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: 2rem;
    }

    .speakers-hero {
      padding: 6rem 0 3rem;
    }

    .avatar-circle {
      width: 100px;
      height: 100px;
      font-size: 1.75rem;
    }

    .speaker-name {
      font-size: 1.25rem;
    }
  }
</style>
