---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
---

<Base title="Bilety | Efekt Feniksa">
  <Nav />
  
  <main class="pt-32 pb-24 min-h-screen bg-surface">
    <div class="max-w-7xl mx-auto px-8">
      <div class="text-center mb-20">
        <span class="text-primary font-bold tracking-widest uppercase text-xs mb-4 block">Rejestracja</span>
        <h1 class="font-headline text-5xl md:text-7xl font-bold mb-6">Bilety / Tickets</h1>
        <p class="text-on-surface-variant text-xl max-w-2xl mx-auto font-light">
          Wybierz swój poziom doświadczenia i dołącz do ognia wspólnoty Toastmasters w Kaliszu.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Standard -->
        <div class="bg-surface-container-low border border-primary/10 p-10 flex flex-col rounded-2xl hover:border-primary/40 transition-all group">
          <h3 class="font-headline text-2xl font-bold mb-2">Standard</h3>
          <div class="text-4xl font-bold text-primary mb-6">€50</div>
          <ul class="space-y-4 mb-10 flex-grow">
            <li class="flex items-center gap-3 text-on-surface-variant">
              <span class="material-symbols-outlined text-primary text-sm">check_circle</span>
              <span>Wstęp na wszystkie konkursy</span>
            </li>
            <li class="flex items-center gap-3 text-on-surface-variant">
              <span class="material-symbols-outlined text-primary text-sm">check_circle</span>
              <span>Pakiet powitalny uczestnika</span>
            </li>
            <li class="flex items-center gap-3 text-on-surface-variant">
              <span class="material-symbols-outlined text-primary text-sm">check_circle</span>
              <span>Przerwy kawowe i networking</span>
            </li>
          </ul>
          <a href="https://goostaura.com/efekt-feniksa" class="w-full py-4 rounded-full border border-primary/40 text-primary font-bold text-center hover:bg-primary/10 transition-all">
            Kup Bilety
          </a>
        </div>

        <!-- VIP -->
        <div class="bg-surface-container-high border-2 border-primary p-10 flex flex-col rounded-2xl relative shadow-[0_0_40px_rgba(255,107,0,0.1)] scale-105 z-10">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-primary text-neutral-950 px-4 py-1 rounded-full text-xs font-bold uppercase tracking-widest">
            Najlepszy Wybór
          </div>
          <h3 class="font-headline text-2xl font-bold mb-2">VIP</h3>
          <div class="text-4xl font-bold text-primary mb-6">€150</div>
          <ul class="space-y-4 mb-10 flex-grow">
            <li class="flex items-center gap-3 text-on-surface-variant">
              <span class="material-symbols-outlined text-primary text-sm">check_circle</span>
              <span>Wszystko z pakietu Standard</span>
            </li>
            <li class="flex items-center gap-3 text-on-surface-variant">
              <span class="material-symbols-outlined text-primary text-sm">check_circle</span>
              <span>Bilet na Galę Finałową</span>
            </li>
            <li class="flex items-center gap-3 text-on-surface-variant">
              <span class="material-symbols-outlined text-primary text-sm">check_circle</span>
              <span>Miejsce w strefie VIP (przód sali)</span>
            </li>
            <li class="flex items-center gap-3 text-on-surface-variant">
              <span class="material-symbols-outlined text-primary text-sm">check_circle</span>
              <span>Dostęp do nagrań z warsztatów</span>
            </li>
          </ul>
          <a href="https://goostaura.com/efekt-feniksa" class="w-full py-4 rounded-full gradient-bg text-neutral-950 font-bold text-center btn-glow transition-all">
            Kup Bilety
          </a>
        </div>

        <!-- Sponsor -->
        <div class="bg-surface-container-low border border-primary/10 p-10 flex flex-col rounded-2xl hover:border-primary/40 transition-all">
          <h3 class="font-headline text-2xl font-bold mb-2">Sponsor</h3>
          <div class="text-2xl font-bold text-primary mb-6">Skontaktuj się</div>
          <ul class="space-y-4 mb-10 flex-grow">
            <li class="flex items-center gap-3 text-on-surface-variant">
              <span class="material-symbols-outlined text-primary text-sm">check_circle</span>
              <span>Logo na materiałach promocyjnych</span>
            </li>
            <li class="flex items-center gap-3 text-on-surface-variant">
              <span class="material-symbols-outlined text-primary text-sm">check_circle</span>
              <span>Stoisko wystawiennicze</span>
            </li>
            <li class="flex items-center gap-3 text-on-surface-variant">
              <span class="material-symbols-outlined text-primary text-sm">check_circle</span>
              <span>Specjalne podziękowania ze sceny</span>
            </li>
          </ul>
          <a href="mailto:kontakt@efektfeniksa.pl" class="w-full py-4 rounded-full border border-primary/40 text-primary font-bold text-center hover:bg-primary/10 transition-all">
            Napisz do nas
          </a>
        </div>
      </div>

      <div class="mt-20 p-10 bg-surface-container-lowest border border-primary/5 rounded-3xl text-center">
        <h4 class="font-headline text-2xl font-bold mb-4">Informacje dodatkowe</h4>
        <p class="text-on-surface-variant font-light">
          Wszystkie bilety obejmują wstęp na wydarzenie w dniach 28-30 sierpnia 2026 w Kaliszu. <br/>
          Ceny w Euro zostaną przeliczone na PLN według kursu operatora płatności.
        </p>
      </div>
    </div>
  </main>
</Base>
