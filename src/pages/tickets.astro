---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
---

<Base title="Bilety | Efekt Feniksa">
  <Nav />
  
  <main class="pt-32 pb-24 px-6 md:px-12 max-w-7xl mx-auto">
    <!-- Header -->
    <header class="mb-20">
      <div class="flex flex-col md:flex-row items-baseline gap-4 mb-4">
        <span class="text-primary font-label text-sm tracking-[0.2em] uppercase">Bilety</span>
        <h1 class="text-5xl md:text-7xl font-headline font-extrabold tracking-tighter text-on-surface">
          Dołącz do nas <span class="text-primary">28-30 sierpnia</span>
        </h1>
      </div>
      <p class="max-w-2xl text-on-surface-variant text-lg font-light leading-relaxed">
        Wybierz tier biletu i dołącz do największego konkursu sztuki mówienia w Polsce. Miejsca ograniczone!
      </p>
    </header>

    <!-- Ticket Tiers -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
      <!-- Standard -->
      <div class="bg-surface-container-low border border-primary/20 p-8 rounded-lg hover:border-primary/60 transition-all duration-300 flex flex-col">
        <h3 class="text-2xl font-headline font-bold text-on-surface mb-2">Standard</h3>
        <p class="text-primary text-3xl font-bold mb-4">€50</p>
        <p class="text-on-surface-variant text-sm font-light mb-6">Dostęp do:</p>
        <ul class="space-y-3 flex-grow text-on-surface-variant text-sm font-light mb-8">
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-sm">check</span>
            Wszystkie konkursy
          </li>
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-sm">check</span>
            Warsztaty
          </li>
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-sm">check</span>
            Networking
          </li>
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-sm">check</span>
            Gala finałowa
          </li>
        </ul>
        <a href="https://goostaura.com/efekt-feniksa" class="block w-full bg-primary/20 text-primary font-bold py-3 rounded-full text-center hover:bg-primary/40 transition-all">
          Kup Bilet
        </a>
      </div>

      <!-- VIP -->
      <div class="bg-surface-container-low border-2 border-primary p-8 rounded-lg relative flex flex-col transform md:scale-105">
        <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-primary text-black px-4 py-1 rounded-full text-xs font-bold uppercase">
          Popularne
        </div>
        <h3 class="text-2xl font-headline font-bold text-on-surface mb-2">VIP</h3>
        <p class="text-primary text-3xl font-bold mb-4">€150</p>
        <p class="text-on-surface-variant text-sm font-light mb-6">Wszystko z Standard +</p>
        <ul class="space-y-3 flex-grow text-on-surface-variant text-sm font-light mb-8">
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-sm">check</span>
            Priorytetowe miejsca
          </li>
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-sm">check</span>
            Meet & Greet z prelegentami
          </li>
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-sm">check</span>
            VIP networking dinner
          </li>
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-sm">check</span>
            Materiały konferencji
          </li>
        </ul>
        <a href="https://goostaura.com/efekt-feniksa" class="block w-full gradient-bg text-black font-bold py-3 rounded-full text-center hover:opacity-90 transition-all">
          Kup Bilet VIP
        </a>
      </div>

      <!-- Sponsor -->
      <div class="bg-surface-container-low border border-primary/20 p-8 rounded-lg hover:border-primary/60 transition-all duration-300 flex flex-col">
        <h3 class="text-2xl font-headline font-bold text-on-surface mb-2">Sponsor</h3>
        <p class="text-primary text-3xl font-bold mb-4">Indywidualnie</p>
        <p class="text-on-surface-variant text-sm font-light mb-6">Dla firm i organizacji:</p>
        <ul class="space-y-3 flex-grow text-on-surface-variant text-sm font-light mb-8">
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-sm">check</span>
            Pakiet grupowy (10+ osób)
          </li>
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-sm">check</span>
            Branding na konferencji
          </li>
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-sm">check</span>
            Strefa VIP
          </li>
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-sm">check</span>
            Dedykowana obsługa
          </li>
        </ul>
        <button class="block w-full bg-primary/20 text-primary font-bold py-3 rounded-full text-center hover:bg-primary/40 transition-all" onclick="window.location='mailto:sponsor@efektfeniksa.pl'">
          Kontakt
        </button>
      </div>
    </div>

    <!-- Event Info -->
    <section class="bg-surface-container-low p-12 rounded-lg border border-primary/20 mb-20">
      <h2 class="text-3xl font-headline font-bold text-on-surface mb-8">Szczegóły Konferencji</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <h3 class="text-primary font-bold uppercase tracking-widest mb-4">Daty</h3>
          <p class="text-on-surface text-lg font-light">28-30 sierpnia 2026</p>
        </div>
        <div>
          <h3 class="text-primary font-bold uppercase tracking-widest mb-4">Lokalizacja</h3>
          <p class="text-on-surface text-lg font-light">
            Pałac Młodzieży<br/>
            ul. Warszawska 5<br/>
            62-800 Kalisz, Polska
          </p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="p-12 bg-gradient-to-br from-surface-container-low to-surface-container-highest relative overflow-hidden">
      <div class="relative z-10 text-center max-w-2xl mx-auto">
        <h2 class="text-3xl font-headline font-bold mb-6 text-on-surface">Nie przegap tej okazji!</h2>
        <p class="text-on-surface-variant mb-8">Liczba miejsc jest ograniczona. Zapewnij sobie swoje miejsce już teraz.</p>
        <a href="https://goostaura.com/efekt-feniksa" class="inline-block bg-[#FF6B00] text-black px-10 py-4 rounded-full font-bold uppercase tracking-[0.2em] hover:scale-105 active:scale-95 transition-all shadow-2xl shadow-primary/30">
          Kup Bilet Teraz
        </a>
      </div>
      <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-primary/10 rounded-full blur-[100px]"></div>
    </section>
  </main>
</Base>
