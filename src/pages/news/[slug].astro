---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const newsEntries = await getCollection('news');
  return newsEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'news'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat('pl-PL', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(date);
}
---

<Base title={entry.data.title} description={entry.data.description}>
  <article class="article">
    <header class="article-header">
      <div class="container-narrow">
        <a href="/news" class="back-link">← Wszystkie aktualności</a>
        <time class="article-date" datetime={entry.data.pubDate.toISOString()}>
          {formatDate(entry.data.pubDate)}
        </time>
        <h1 class="article-title">{entry.data.title}</h1>
        <p class="article-author">Autor: {entry.data.author}</p>
      </div>
    </header>

    <div class="article-content">
      <div class="container-narrow">
        <Content />
      </div>
    </div>
  </article>
</Base>

<style>
  .article {
    padding-top: 5rem;
    padding-bottom: 5rem;
  }

  .container-narrow {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .article-header {
    margin-bottom: 3rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--gold-primary);
    margin-bottom: 2rem;
    transition: transform 0.3s ease;
  }

  .back-link:hover {
    transform: translateX(-4px);
  }

  .article-date {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--gold-primary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 1rem;
  }

  .article-title {
    font-size: 3rem;
    line-height: 1.2;
    color: var(--text-ebony);
    margin-bottom: 1rem;
  }

  .article-author {
    font-size: 1rem;
    color: var(--text-ebony);
    opacity: 0.7;
  }

  .article-content {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--text-ebony);
  }

  .article-content :global(h2) {
    font-size: 2rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--gold-primary);
  }

  .article-content :global(h3) {
    font-size: 1.5rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--text-ebony);
  }

  .article-content :global(p) {
    margin-bottom: 1.5rem;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .article-content :global(li) {
    margin-bottom: 0.75rem;
  }

  .article-content :global(strong) {
    font-weight: 700;
    color: var(--gold-primary);
  }

  .article-content :global(a) {
    color: var(--gold-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.3s ease;
  }

  .article-content :global(a:hover) {
    opacity: 0.8;
  }

  .article-content :global(blockquote) {
    border-left: 4px solid var(--gold-primary);
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    opacity: 0.9;
  }

  @media (max-width: 768px) {
    .article {
      padding-top: 4rem;
      padding-bottom: 4rem;
    }

    .article-title {
      font-size: 2rem;
    }

    .article-content {
      font-size: 1rem;
    }

    .article-content :global(h2) {
      font-size: 1.5rem;
    }

    .article-content :global(h3) {
      font-size: 1.25rem;
    }
  }
</style>
