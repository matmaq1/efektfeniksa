---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allNews = await getCollection('news');
  return allNews.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Base title={`${post.data.title} | Efekt Feniksa`}>
  <Nav />
  
  <main class="pt-32 pb-24 px-6 md:px-12 max-w-4xl mx-auto">
    <!-- Back Link -->
    <a href="/news" class="inline-flex items-center gap-2 text-primary font-bold uppercase tracking-wider text-sm mb-12 hover:text-primary/80 transition-colors">
      <span class="material-symbols-outlined text-sm">arrow_back</span>
      Back to News
    </a>

    <!-- Article Header -->
    <header class="mb-12">
      <h1 class="text-5xl md:text-7xl font-headline font-extrabold tracking-tighter text-on-surface mb-6">
        {post.data.title}
      </h1>
      <div class="flex items-center gap-4 text-on-surface-variant text-sm">
        <span>{post.data.date.toLocaleDateString('pl-PL')}</span>
        <span>•</span>
        <span>Efekt Feniksa</span>
      </div>
    </header>

    <!-- Article Content -->
    <article class="prose prose-invert max-w-none">
      <Content />
    </article>

    <!-- CTA Section -->
    <section class="mt-24 p-12 bg-gradient-to-br from-surface-container-low to-surface-container-highest relative overflow-hidden">
      <div class="relative z-10 text-center max-w-2xl mx-auto">
        <h2 class="text-3xl font-headline font-bold mb-6 text-on-surface">Interested? Don't miss out.</h2>
        <p class="text-on-surface-variant mb-8">Register now to be part of Efekt Feniksa and experience the magic of public speaking.</p>
        <button class="bg-[#FF6B00] text-black px-10 py-4 rounded-full font-bold uppercase tracking-[0.2em] hover:scale-105 active:scale-95 transition-all shadow-2xl shadow-primary/30">
          Register Now
        </button>
      </div>
      <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-primary/10 rounded-full blur-[100px]"></div>
    </section>
  </main>

  <style>
    /* Prose customizations for dark theme */
    .prose {
      --prose-body: #e6e1e1;
      --prose-headings: #e6e1e1;
      --prose-links: #FF6B00;
      --prose-code: #FF6B00;
      --prose-hr: #363434;
      --prose-quotes: #d1c5b4;
      --prose-captions: #d1c5b4;
      --prose-th-borders: #363434;
      --prose-td-borders: #201f1f;
    }

    :global(.prose) p {
      color: #e6e1e1;
      line-height: 1.8;
    }

    :global(.prose) h2, :global(.prose) h3 {
      color: #e6e1e1;
      font-family: 'Noto Serif', serif;
      margin-top: 2rem;
      margin-bottom: 1rem;
    }

    :global(.prose) a {
      color: #FF6B00;
      text-decoration: none;
      border-bottom: 1px solid #FF6B00;
    }

    :global(.prose) a:hover {
      opacity: 0.8;
    }

    :global(.prose) blockquote {
      border-left: 4px solid #FF6B00;
      color: #d1c5b4;
      font-style: italic;
    }

    :global(.prose) strong {
      color: #FF6B00;
    }
  </style>
</Base>
