---
import Layout from '../layouts/Base.astro';
import { Nav, Hero, SpeakersStrip, Venue, FinalCTA, Footer, EmberField, HeatDistortion } from '../components/Sections.jsx';
import { Agenda } from '../components/Agenda.jsx';
import { SpeakersGallery } from '../components/SpeakersGallery.jsx';
import { ALL_SPEAKERS, AGENDA_DAYS, GALLERY } from '../data/agenda.ts';
import '../styles/global.css';
---

<Layout title="Feniks · Kalisz 2026">
  <div id="app" class="bg-background text-on-surface antialiased overflow-x-hidden">
    <Nav active="home" client:load />
    <Hero client:load />
    <SpeakersStrip speakers={ALL_SPEAKERS} client:visible />
    <div class="bg-surface relative z-20">
      <SpeakersGallery entries={GALLERY} client:visible />
      <Venue client:visible />
      <Agenda days={AGENDA_DAYS} client:visible />
      <FinalCTA client:visible />
    </div>
    <Footer client:visible />
  </div>
</Layout>
