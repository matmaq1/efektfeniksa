<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Efekt Feniksa - Mistrzostwa Polski Toastmasters 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;800&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#000110;--bl:#050571;--o:#FF5B00;--g:#FCA311;--w:#fff;--w6:rgba(255,255,255,.6);--w1:rgba(255,255,255,.08);--w05:rgba(255,255,255,.05);--dark-o:#C44400}
html{scroll-behavior:smooth}
body{font-family:'Montserrat',sans-serif;background:var(--bg);color:var(--w);overflow-x:hidden;-webkit-font-smoothing:antialiased;background-image:radial-gradient(ellipse 80% 50% at 30% 20%,rgba(5,5,113,.4) 0%,transparent 60%),radial-gradient(ellipse 70% 50% at 80% 70%,rgba(5,5,113,.35) 0%,transparent 65%);background-attachment:fixed}
img{display:block;max-width:100%}
#cv{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:0 5%;height:68px;display:flex;align-items:center;justify-content:space-between;transition:background .4s}
nav.sc{background:rgba(0,1,16,.92);backdrop-filter:blur(14px);border-bottom:1px solid rgba(252,163,17,.1)}
.logo{display:flex;align-items:center;gap:9px;text-decoration:none}
.logo .b{font-weight:800;font-size:16px;letter-spacing:-.04em;color:var(--w)}
.logo .l{font-weight:400;font-size:10px;letter-spacing:.18em;color:var(--w6)}
.nl{display:flex;gap:26px;list-style:none;align-items:center}
.nl a{text-decoration:none;font-weight:700;font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--w6);transition:color .2s}
.nl a:hover{color:var(--g)}
.ncta{background:linear-gradient(135deg,var(--o),var(--g));color:var(--bg)!important;padding:7px 16px;border-radius:2px;font-weight:800!important}
.hbg{display:none;background:none;border:none;cursor:pointer;flex-direction:column;gap:5px;padding:4px}
.hbg span{display:block;width:22px;height:2px;background:var(--w);transition:.3s}
.hbg.open span:nth-child(1){transform:rotate(45deg) translate(5px,5px)}
.hbg.open span:nth-child(2){opacity:0}
.hbg.open span:nth-child(3){transform:rotate(-45deg) translate(5px,-5px)}

/* COUNTDOWN */
#cb{position:relative;z-index:2;background:linear-gradient(90deg,rgba(255,91,0,.09),rgba(252,163,17,.06),rgba(255,91,0,.09));border-bottom:1px solid rgba(252,163,17,.11);padding:9px 5%;display:flex;align-items:center;justify-content:center;gap:14px;margin-top:68px;flex-wrap:wrap}
.clbl{font-size:10px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--o)}
.cu{display:flex;gap:2px}
.cun{display:flex;flex-direction:column;align-items:center;background:rgba(0,0,0,.3);border:1px solid rgba(252,163,17,.11);padding:5px 11px;min-width:54px}
.cn{font-size:20px;font-weight:800;letter-spacing:-.05em;line-height:1}
.cnm{font-size:8px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--w6);margin-top:2px}
.cs{font-size:16px;font-weight:800;color:var(--o);align-self:center;padding:0 3px}

/* HERO */
#hero{position:relative;min-height:86vh;display:flex;align-items:center;padding:36px 5% 70px;overflow:hidden}
.hbi{position:absolute;inset:0;z-index:0;background-image:url('https://images.unsplash.com/photo-1475721027785-f74eccf877e2?auto=format&fit=crop&w=1600&q=70');background-size:cover;background-position:center 30%;filter:brightness(.16) saturate(.5)}
.hbo{position:absolute;inset:0;z-index:1;background:linear-gradient(105deg,rgba(0,1,16,.85) 30%,rgba(5,5,113,.65) 100%),radial-gradient(ellipse 50% 70% at 80% 50%,rgba(5,5,113,.5),transparent 70%)}
.hc{position:relative;z-index:2;max-width:760px}
.hlbl{font-size:10px;font-weight:700;letter-spacing:.22em;color:var(--g);text-transform:uppercase;margin-bottom:18px;display:flex;align-items:center;gap:10px}
.hlbl::before{content:'';display:block;width:24px;height:1px;background:var(--g)}
h1{font-size:clamp(34px,5.4vw,66px);font-weight:800;letter-spacing:-.05em;line-height:1.05;margin-bottom:20px}
h1 .l1,h1 .l2{display:block}
.fire{background:linear-gradient(135deg,var(--g),var(--o));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hsub{font-size:17px;font-weight:700;letter-spacing:-.02em;color:var(--g);line-height:1.4;margin-bottom:32px;max-width:520px}
.hmeta{display:flex;flex-direction:column;align-items:flex-start;gap:6px;margin-bottom:34px}
.hmi{font-size:17px;font-weight:800;letter-spacing:-.03em}
.hbtns{display:flex;gap:11px;flex-wrap:wrap}
.sarr{width:1px;height:32px;background:linear-gradient(to bottom,var(--w),transparent);animation:sp 2s ease-in-out infinite}
@keyframes sp{0%,100%{opacity:.3}50%{opacity:.9}}
.scroll-h{position:absolute;bottom:24px;left:50%;transform:translateX(-50%);z-index:2;display:flex;flex-direction:column;align-items:center;gap:6px;opacity:.28;font-size:9px;letter-spacing:.2em;text-transform:uppercase}

/* BUTTONS */
.bp{display:inline-flex;align-items:center;gap:7px;background:linear-gradient(135deg,var(--o),var(--g));color:var(--bg);font-family:'Montserrat',sans-serif;font-weight:800;font-size:11px;letter-spacing:.08em;text-transform:uppercase;text-decoration:none;padding:13px 28px;border-radius:2px;border:none;cursor:pointer;transition:transform .2s,opacity .2s}
.bp:hover{transform:translateY(-2px);opacity:.9}
.bs{display:inline-flex;align-items:center;gap:7px;background:transparent;color:var(--w);font-family:'Montserrat',sans-serif;font-weight:700;font-size:11px;letter-spacing:.08em;text-transform:uppercase;text-decoration:none;padding:12px 28px;border-radius:2px;border:1px solid rgba(255,255,255,.15);cursor:pointer;transition:border-color .2s,color .2s}
.bs:hover{border-color:var(--g);color:var(--g)}
.bd{display:block;width:100%;text-align:center;padding:11px;border:1px solid rgba(255,255,255,.1);color:var(--w6);font-family:'Montserrat',sans-serif;font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;background:none;cursor:not-allowed;border-radius:2px;opacity:.5}

/* FLINE */
.fl{width:100%;height:1px;background:linear-gradient(90deg,transparent,var(--o),var(--g),transparent);opacity:.2}

/* PARTNERZY BIALY PASEK */
#partnerzy{background:var(--w);padding:48px 5%;position:relative;z-index:2;overflow:hidden}
.partnerzy-wrap{max-width:1100px;margin:0 auto;position:relative;display:flex;flex-direction:column;align-items:center;gap:24px}
.partnerzy-tit{font-size:11px;font-weight:800;letter-spacing:.24em;color:var(--dark-o);text-transform:uppercase}
.partnerzy-logos{display:flex;align-items:center;justify-content:center;gap:64px;flex-wrap:wrap;position:relative;z-index:2}
.pl-box{height:60px;min-width:160px;display:flex;align-items:center;justify-content:center;padding:10px 22px;border:1px dashed #d4d4d4;border-radius:2px;color:#999;font-size:11px;font-weight:700;letter-spacing:.06em;text-align:center;text-transform:uppercase;line-height:1.4}
.partnerzy-decor{position:absolute;right:-80px;top:50%;transform:translateY(-50%);width:280px;height:280px;pointer-events:none;z-index:1;display:flex;align-items:center;justify-content:center}
.mist{position:absolute;inset:0;background:none;filter:blur(28px)}
.phoenix-decor{position:relative;z-index:2;width:120px;height:120px;opacity:.92}

/* SECTIONS COMMON */
section{position:relative;z-index:2;padding:80px 5%}
.slb{font-size:10px;font-weight:700;letter-spacing:.2em;color:var(--o);text-transform:uppercase;margin-bottom:12px;display:flex;align-items:center;gap:8px}
.slb::before{content:'';display:block;width:18px;height:1px;background:var(--o)}
.st{font-size:clamp(26px,3.5vw,42px);font-weight:800;letter-spacing:-.05em;line-height:1.05;margin-bottom:12px}
.sd{font-size:14px;font-weight:400;letter-spacing:-.02em;color:var(--w6);line-height:1.7;max-width:560px}
.sh{margin-bottom:46px}
.deco{font-size:clamp(56px,11vw,140px);font-weight:800;letter-spacing:.222em;color:rgba(255,255,255,.018);text-transform:uppercase;position:absolute;pointer-events:none;user-select:none;white-space:nowrap}

/* O WYDARZENIU */
#onas{background:linear-gradient(180deg,transparent 0%,rgba(5,5,113,.12) 100%)}
.ag{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:start}
.asg{display:grid;grid-template-columns:1fr 1fr;gap:2px}
.sb{background:rgba(5,5,113,.18);border:1px solid rgba(255,255,255,.06);padding:24px 18px;position:relative;overflow:hidden}
.sb::after{content:'';position:absolute;bottom:0;left:0;width:100%;height:2px;background:linear-gradient(90deg,var(--o),transparent);opacity:0;transition:opacity .3s}
.sb:hover::after{opacity:1}
.sn{font-size:42px;font-weight:800;letter-spacing:-.05em;line-height:1;background:linear-gradient(135deg,var(--g),var(--o));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:5px}
.sl{font-size:9px;font-weight:700;letter-spacing:.13em;text-transform:uppercase;color:var(--w6)}
.at{display:flex;flex-direction:column;gap:18px}
.at p{font-size:14px;font-weight:400;letter-spacing:-.02em;line-height:1.75;color:var(--w6)}
.at p strong{color:var(--w);font-weight:700}
.at p.highlight{font-size:15px;color:var(--g);font-weight:700;border-left:3px solid var(--o);padding-left:18px}

/* PROGRAM */
#program{background:linear-gradient(180deg,rgba(5,5,113,.12) 0%,rgba(5,5,113,.2) 100%)}
.agenda-note{display:flex;align-items:flex-start;gap:10px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-left:3px solid var(--g);padding:12px 16px;margin-bottom:36px;max-width:700px}
.agenda-note p{font-size:12px;font-weight:700;color:var(--g);letter-spacing:.01em;line-height:1.5}
.dtabs{display:flex;border-bottom:1px solid rgba(255,255,255,.07);overflow-x:auto;margin-bottom:36px}
.dtab{padding:12px 22px;font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--w6);cursor:pointer;border:none;border-bottom:2px solid transparent;margin-bottom:-1px;transition:color .2s,border-color .2s;background:none;font-family:'Montserrat',sans-serif;white-space:nowrap}
.dtab.active{color:var(--g);border-bottom-color:var(--g)}
.dtab:hover:not(.active){color:var(--w)}
.dp{display:none;min-height:160px;padding:48px 0;text-align:center}
.dp.active{display:block}
.dp-empty{font-size:13px;font-weight:700;letter-spacing:.05em;color:var(--w6);font-style:italic;opacity:.7}
.dp-empty::before{content:'⏳';display:block;font-size:32px;margin-bottom:14px;opacity:.5;font-style:normal}

/* PRELEGENCI */
#prelegenci{background:linear-gradient(180deg,rgba(5,5,113,.2) 0%,transparent 100%)}
.spc{border:1px dashed rgba(252,163,17,.2);padding:64px 32px;text-align:center;position:relative;overflow:hidden}
.spc::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 80% at 50% 50%,rgba(5,5,113,.25),transparent)}
.spc h3{font-size:24px;font-weight:800;letter-spacing:-.05em;margin-bottom:9px;position:relative;z-index:1}
.spc p{font-size:13px;font-weight:400;color:var(--w6);max-width:400px;margin:0 auto 20px;line-height:1.6;position:relative;z-index:1}
.sgh{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:32px;position:relative;z-index:1}
.sgc{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.05);padding:22px 16px;filter:blur(1.5px);opacity:.28}
.sga{width:48px;height:48px;border-radius:50%;background:rgba(255,255,255,.05);margin-bottom:11px}
.sgl{height:8px;background:rgba(255,255,255,.05);border-radius:2px;margin-bottom:6px}

/* BILETY */
#bilety{background:linear-gradient(180deg,transparent 0%,rgba(5,5,113,.15) 100%)}
.csbg{display:inline-flex;align-items:center;gap:5px;font-size:9px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;background:rgba(252,163,17,.07);border:1px solid rgba(252,163,17,.2);color:var(--g);padding:4px 11px;border-radius:2px;margin-bottom:32px}
.tgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
.tc{background:rgba(5,5,113,.15);border:1px solid rgba(255,255,255,.06);padding:30px 22px;position:relative;overflow:hidden;transition:transform .3s,border-color .3s}
.tc:hover{transform:translateY(-3px);border-color:rgba(252,163,17,.18)}
.tc.feat{background:linear-gradient(160deg,rgba(255,91,0,.13),rgba(252,163,17,.08));border-color:rgba(252,163,17,.32);border-width:2px}
.tbg{position:absolute;top:12px;right:12px;font-size:8px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:3px 7px;background:linear-gradient(135deg,var(--o),var(--g));color:var(--bg);border-radius:2px}
.ttype{font-size:9px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--w6);margin-bottom:7px}
.tnmb{font-size:19px;font-weight:800;letter-spacing:-.05em;margin-bottom:6px}
.tnmb.feat-nm{background:linear-gradient(135deg,var(--g),var(--o));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.tsub{font-size:11px;font-weight:700;letter-spacing:.04em;font-style:italic;color:var(--w6);margin-bottom:18px}
.pph{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--w6);background:rgba(255,255,255,.04);border:1px dashed rgba(255,255,255,.09);padding:4px 11px;border-radius:2px;display:inline-block;margin-bottom:6px}
.pph.fp{color:var(--g);border-color:rgba(252,163,17,.18);background:rgba(252,163,17,.04)}
.tper{font-size:11px;font-weight:400;color:var(--w6);margin-bottom:20px;letter-spacing:-.01em}
.tfl{list-style:none;display:flex;flex-direction:column;gap:8px;margin-bottom:22px}
.tfl li{display:flex;align-items:center;gap:8px;font-size:12px;font-weight:400;color:var(--w6)}
.tfl li.chk::before{content:'✓';width:15px;height:15px;min-width:15px;border-radius:50%;background:linear-gradient(135deg,var(--o),var(--g));font-size:8px;font-weight:800;color:var(--bg);display:flex;align-items:center;justify-content:center}
.tfl li.gr::before{content:'';width:15px;height:15px;min-width:15px;border-radius:50%;background:rgba(255,255,255,.04);display:flex;align-items:center;justify-content:center}

/* DLACZEGO KALISZ - REWORKED with hover reveals */
#kalisz{background:linear-gradient(180deg,rgba(5,5,113,.15) 0%,transparent 100%)}
.kreasons{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;height:420px}
.kreason{position:relative;overflow:hidden;cursor:pointer;background:#000}
.kreason img{width:100%;height:100%;object-fit:cover;filter:brightness(.55) saturate(.75);transition:filter .5s ease,transform .6s ease;display:block}
.kreason:hover img{filter:brightness(.28) saturate(.6);transform:scale(1.06)}
.kreason-overlay{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;padding:32px 26px;background:linear-gradient(to top,rgba(0,1,16,.85) 0%,rgba(0,1,16,.4) 40%,transparent 75%);transition:background .4s ease}
.kreason:hover .kreason-overlay{background:linear-gradient(to top,rgba(0,1,16,.95) 0%,rgba(0,1,16,.7) 50%,rgba(0,1,16,.3) 100%)}
.kreason-title{font-size:22px;font-weight:800;letter-spacing:-.04em;line-height:1.15;margin-bottom:0;transition:transform .45s ease,margin-bottom .45s ease;color:var(--w)}
.kreason:hover .kreason-title{margin-bottom:14px}
.kreason-text{font-size:13px;color:var(--w6);line-height:1.65;letter-spacing:-.01em;max-height:0;opacity:0;overflow:hidden;transition:max-height .5s ease,opacity .4s ease}
.kreason:hover .kreason-text{max-height:260px;opacity:1}
.kreason-tag{display:inline-block;font-size:9px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--g);margin-bottom:8px;background:rgba(252,163,17,.12);padding:3px 9px;border:1px solid rgba(252,163,17,.22);border-radius:2px;width:fit-content}

/* LOKALIZACJA - mapa OBOK info i tytulu */
#lokalizacja{background:transparent;padding:80px 5%}
.lokaliz-grid{display:grid;grid-template-columns:1fr 1.3fr;gap:48px;align-items:start}
.lokaliz-left{display:flex;flex-direction:column;gap:28px}
.lokaliz-left .sh{margin-bottom:0}
.linfo{display:flex;flex-direction:column;gap:20px}
.li{display:flex;gap:14px;align-items:flex-start}
.lic{width:38px;height:38px;min-width:38px;background:rgba(255,91,0,.07);border:1px solid rgba(255,91,0,.15);border-radius:2px;display:flex;align-items:center;justify-content:center;font-size:16px}
.lil{font-size:9px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--o);margin-bottom:2px}
.liv{font-size:14px;font-weight:800;letter-spacing:-.03em;margin-bottom:2px}
.lis{font-size:12px;font-weight:400;color:var(--w6);letter-spacing:-.01em;line-height:1.5}
.mapwrap{border:1px solid rgba(255,255,255,.07);border-radius:2px;overflow:hidden;height:540px;position:sticky;top:90px}
.mapwrap iframe{width:100%;height:100%;border:0;display:block;filter:grayscale(.2) invert(.86) hue-rotate(180deg) brightness(.82) contrast(1.1) saturate(.6)}

/* FAQ */
#faq{background:transparent}
.fl2{display:flex;flex-direction:column;gap:2px;max-width:760px}
.fi{border:1px solid rgba(255,255,255,.06);background:rgba(5,5,113,.15);overflow:hidden}
.fq{width:100%;padding:17px 20px;background:none;border:none;cursor:pointer;font-family:'Montserrat',sans-serif;font-weight:700;font-size:13px;letter-spacing:-.03em;color:var(--w);text-align:left;display:flex;justify-content:space-between;align-items:center;gap:12px}
.fq:hover{color:var(--g)}
.fa2{font-size:17px;color:var(--o);transition:transform .3s;flex-shrink:0}
.fi.open .fa2{transform:rotate(45deg)}
.fans{max-height:0;overflow:hidden;transition:max-height .35s ease}
.fai{padding:0 20px 16px;font-size:13px;font-weight:400;letter-spacing:-.01em;color:var(--w6);line-height:1.7}
.fi.open .fans{max-height:280px}

/* CTA */
#kontakt{text-align:center;padding:100px 5%;position:relative;overflow:hidden}
.ctabg{position:absolute;inset:0;background:radial-gradient(ellipse 60% 80% at 50% 50%,rgba(5,5,113,.55),transparent)}
.ctac{position:relative;z-index:1;max-width:660px;margin:0 auto}
.ctae{font-size:10px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--g);margin-bottom:16px}
.ctat{font-size:clamp(26px,4.2vw,50px);font-weight:800;letter-spacing:-.05em;line-height:1;margin-bottom:18px}
.ctas{font-size:14px;font-weight:400;letter-spacing:-.02em;color:var(--w6);line-height:1.6;margin-bottom:36px}
.ctabtns{display:flex;gap:11px;justify-content:center;flex-wrap:wrap}

/* FOOTER */
footer{position:relative;z-index:2;padding:40px 5% 22px;border-top:1px solid rgba(255,255,255,.05);background:rgba(0,1,16,.5)}
.ftop{display:grid;grid-template-columns:1fr auto;gap:36px;margin-bottom:32px;align-items:start}
.flinks{display:flex;gap:20px;flex-wrap:wrap;margin-top:14px}
.flinks a{text-decoration:none;font-size:10px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:var(--w6);transition:color .2s}
.flinks a:hover{color:var(--g)}
.fsl{width:36px;height:36px;border:1px solid rgba(255,255,255,.1);border-radius:2px;display:inline-flex;align-items:center;justify-content:center;text-decoration:none;font-size:12px;font-weight:800;color:var(--w6);transition:border-color .2s,color .2s}
.fsl:hover{border-color:var(--g);color:var(--g)}
.fcopy{font-size:10px;font-weight:400;color:rgba(255,255,255,.18);letter-spacing:.04em;margin-top:18px}
.flegal{display:flex;gap:18px;margin-top:8px;flex-wrap:wrap}
.flegal a{font-size:10px;color:rgba(255,255,255,.4);text-decoration:none;letter-spacing:.06em}
.flegal a:hover{color:var(--g)}

/* RESPONSIVE */
@media(max-width:1024px){
  .tgrid{grid-template-columns:1fr 1fr}
  .sgh{grid-template-columns:1fr 1fr}
  .sgh .sgc:last-child{display:none}
  .kreasons{grid-template-columns:1fr;height:auto}
  .kreason{height:280px}
  .kreason-overlay{background:linear-gradient(to top,rgba(0,1,16,.92) 0%,rgba(0,1,16,.65) 50%,rgba(0,1,16,.25) 100%)}
  .kreason-title{margin-bottom:14px}
  .kreason-text{max-height:260px;opacity:1}
}
@media(max-width:900px){
  .ag,.lokaliz-grid{grid-template-columns:1fr;gap:36px}
  .mapwrap{height:340px;position:relative;top:auto}
  .nl{display:none}
