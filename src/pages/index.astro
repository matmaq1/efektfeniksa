}
function showDay(id,btn){
  document.querySelectorAll('.dp').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.dtab').forEach(t=>t.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  btn.classList.add('active');
}
function faq(btn){
  const it=btn.closest('.fi');
  const op=it.classList.contains('open');
  document.querySelectorAll('.fi').forEach(i=>i.classList.remove('open'));
  if(!op)it.classList.add('open');
}
function tick(){
  const diff=new Date('2026-08-28T00:00:00')-new Date();
  if(diff<=0){document.getElementById('cb').innerHTML='<div class="clbl" style="color:var(--g)">Mistrzostwa trwają!</div>';return;}
  const d=Math.floor(diff/86400000),h=Math.floor(diff%86400000/3600000),m=Math.floor(diff%3600000/60000),s=Math.floor(diff%60000/1000);
  document.getElementById('cd').textContent=String(d).padStart(3,'0');
  document.getElementById('ch').textContent=String(h).padStart(2,'0');
  document.getElementById('cm').textContent=String(m).padStart(2,'0');
  document.getElementById('cs2').textContent=String(s).padStart(2,'0');
}
tick();setInterval(tick,1000);

const cv=document.getElementById('cv'),cx=cv.getContext('2d');
function rsz(){cv.width=innerWidth;cv.height=innerHeight;}
rsz();addEventListener('resize',rsz);
const pts=[];
function mkp(){return{x:Math.random()*innerWidth,y:innerHeight*.05+Math.random()*innerHeight*.9,vx:(Math.random()-.5)*.7,vy:-Math.random()*1.1-.15,l:0,ml:130+Math.random()*200,sz:.7+Math.random()*1.9,c:Math.random()>.5?'#FF5B00':'#FCA311'};}
for(let i=0;i<130;i++){const p=mkp();p.l=Math.random()*p.ml;pts.push(p);}
(function anim(){
  cx.clearRect(0,0,cv.width,cv.height);
  for(const p of pts){
    p.l++;if(p.l>p.ml)Object.assign(p,mkp(),{l:0});
    const a=Math.sin(p.l/p.ml*Math.PI)*.55;
    p.x+=p.vx+Math.sin(p.l*.04)*.22;p.y+=p.vy;
    cx.save();cx.globalAlpha=a;cx.fillStyle=p.c;cx.shadowBlur=5;cx.shadowColor=p.c;cx.beginPath();cx.arc(p.x,p.y,p.sz,0,Math.PI*2);cx.fill();cx.restore();
  }
  requestAnimationFrame(anim);
})();

const obs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.style.opacity='1';e.target.style.transform='translateY(0)';}}),{threshold:.07});
document.querySelectorAll('section,.sb,.tc,.fi,.li,.kreason').forEach(el=>{
  el.style.opacity='0';el.style.transform='translateY(16px)';el.style.transition='opacity .55s ease,transform .55s ease';
  obs.observe(el);
});
document.getElementById('hero').style.cssText+='opacity:1!important;transform:none!important;';
</script>
</body>
</html>
