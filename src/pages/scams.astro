---
const scams = [
  {
    title: "Upadek Imperium FTX",
    perpetrator: "Sam Bankman-Fried",
    year: "2022-2024",
    loss: "$8-10 miliardów",
    description: "Jedna z największych katastrof w historii krypto. Środki klientów były używane do ryzykownych inwestycji przez fundusz Alameda Research. SBF skazany na 25 lat więzienia."
  },
  {
    title: "Deepfake AI Scams",
    perpetrator: "Zorganizowane grupy cyber",
    year: "2024-2025",
    loss: "$100+ milionów",
    description: "Wykorzystywanie AI do generowania realistycznych wizerunków (np. Elon Musk, polscy celebryci) promujących fałszywe platformy inwestycyjne. Głośna sprawa pracownika w Hong Kongu, który przelewał miliony po rozmowie z AI-szefem."
  },
  {
    title: "Piramidy Krypto-AI",
    perpetrator: "Różne podmioty",
    year: "2024",
    loss: "Brak precyzyjnych danych",
    description: "Nowa fala piramid finansowych obiecujących 'gwarantowane zyski' dzięki magicznym algorytmom AI tradingowym. Wykorzystują niewiedzę ludzi o technologii do zbierania depozytów."
  }
];
---
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <title>Analiza Przekrętów Finansowych | KonfEvent 2026</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
</head>
<body class="bg-gray-900 text-white font-sans p-8">
    <div class="max-w-4xl mx-auto">
        <header class="mb-12 border-b border-red-500 pb-6">
            <h1 class="text-4xl font-black text-red-500 mb-2">ARCHIWUM PRZEKRĘTÓW</h1>
            <p class="text-gray-400">Analiza największych malwersacji ostatnich lat – lekcja dla organizatorów i inwestorów.</p>
        </header>

        <div class="space-y-8">
            {scams.map((scam) => (
                <div class="bg-gray-800 border-l-4 border-red-600 p-6 rounded-r-lg shadow-xl hover:bg-gray-750 transition-all">
                    <div class="flex justify-between items-start mb-4">
                        <h2 class="text-2xl font-bold">{scam.title}</h2>
                        <span class="bg-red-900 text-red-200 px-3 py-1 rounded text-xs font-mono">{scam.year}</span>
                    </div>
                    <div class="grid grid-cols-2 gap-4 mb-4 text-sm">
                        <div>
                            <p class="text-gray-500 uppercase tracking-tighter text-xs">Sprawca / Podmiot</p>
                            <p class="font-mono text-gray-300">{scam.perpetrator}</p>
                        </div>
                        <div>
                            <p class="text-gray-500 uppercase tracking-tighter text-xs">Szacowane straty</p>
                            <p class="font-mono text-red-400 font-bold">{scam.loss}</p>
                        </div>
                    </div>
                    <p class="text-gray-400 leading-relaxed text-sm">
                        {scam.description}
                    </p>
                </div>
            ))}
        </div>

        <footer class="mt-16 text-center text-gray-600 text-xs">
            <p>Raport przygotowany przez Konfi Julkę dla celów edukacyjnych i testowych.</p>
            <a href="/" class="text-red-500 hover:underline mt-4 inline-block">← Powrót do menu głównego</a>
        </footer>
    </div>
</body>
</html>